default_platform(:ios)

# Monkey-patch: OpenSSL::PKey::EC.new fails with "invalid curve name"
# on OpenSSL 3.x when given PKCS#8 format (BEGIN PRIVATE KEY).
# Fallback to OpenSSL::PKey.read which handles it correctly.
require 'openssl'
module OpenSSLCurveNameFix
  def initialize(*args)
    super
  rescue OpenSSL::PKey::PKeyError, OpenSSL::PKey::ECError => e
    raise unless args.first.is_a?(String) && args.length == 1
    key = OpenSSL::PKey.read(args.first)
    super(key.to_der)
  end
end
OpenSSL::PKey::EC.prepend(OpenSSLCurveNameFix)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_FILEPATH"],
    )

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"],
      xcodeproj: "iosApp.xcodeproj"
    )

    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "dev.anthonyhfm.amethyst.Amethyst" => "match AppStore dev.anthonyhfm.amethyst.Amethyst"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
