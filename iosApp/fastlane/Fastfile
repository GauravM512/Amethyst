require 'openssl'

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    # Apple .p8 keys use PKCS#8 format (BEGIN PRIVATE KEY) which causes
    # "invalid curve name" on OpenSSL 3.x via EC.new(). Convert to
    # traditional EC format (BEGIN EC PRIVATE KEY) which works everywhere.
    raw_key = File.read(ENV["ASC_API_KEY_FILEPATH"])
    ec_key = OpenSSL::PKey.read(raw_key)
    ec_pem = ec_key.to_pem

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ec_pem,
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    increment_build_number(
      build_number: ENV["BUILD_NUMBER"],
      xcodeproj: "iosApp.xcodeproj"
    )

    build_app(
      scheme: "iosApp",
      project: "iosApp.xcodeproj",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "dev.anthonyhfm.amethyst.Amethyst" => "match AppStore dev.anthonyhfm.amethyst.Amethyst"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
